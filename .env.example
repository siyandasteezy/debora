# Application
APP_ENV=production
APP_SECRET_KEY=replace-with-a-random-64-char-string
APP_DEBUG=false

# Database — get from Neon (neon.tech) or Render managed DB
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# Redis — get from Upstash (upstash.com)
REDIS_URL=redis://default:password@host:port

# Qdrant — get from Qdrant Cloud (cloud.qdrant.io)
QDRANT_HOST=your-cluster-id.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=mental_health_knowledge

# Embeddings (local — no API key needed)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70
RAG_RERANK_TOP_K=3

# Safety
CRISIS_CONFIDENCE_THRESHOLD=0.75
SAFETY_LOG_ALL=true

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# CORS — set to your Vercel frontend URL
CORS_ORIGINS=https://your-app.vercel.app

# Optional — only needed if you add LLM features later
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
